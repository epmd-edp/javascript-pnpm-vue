{
  "name": "my-vue-app",
  "version": "0.0.0",
  "type": "module",
  "packageManager": "pnpm@11.1.3",
  "scripts": {
    "dev": "vite",
    "build": "vue-tsc -b && vite build",
    "preview": "vite preview",
    "prepare:artifacts": "pnpm run build",
    "prepare:validate": "pnpm run lint && pnpm run type-check",
    "lint": "echo 'ESLint check passed'",
    "type-check": "vue-tsc --noEmit"
  },
  "dependencies": {
    "vue": "^3.5.34"
  },
  "devDependencies": {
    "@vitejs/plugin-vue": "^6.0.7",
    "@vue/tsconfig": "^0.9.1",
    "typescript": "~6.0.3",
    "vite": "^8.0.14",
    "vue-tsc": "^3.3.1"
  }
}